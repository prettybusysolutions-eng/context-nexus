# Context Nexus — Environment Variables
# Copy to .env and fill in values

# ── Storage ────────────────────────────────────────────────────────────────────
# SQLite path (default)
CONTEXT_NEXUS_DB_DIR=~/.openclaw/context-nexus
CONTEXT_NEXUS_DB_PATH=~/.openclaw/context-nexus/nexus.db

# PostgreSQL (optional — overrides SQLite if set)
# DATABASE_URL=postgresql://user:pass@host:5432/nexus

# ── Encryption ────────────────────────────────────────────────────────────────
# Custom encryption key for secrets (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
# Default uses a built-in key only suitable for local dev
CONTEXT_NEXUS_ENCRYPTION_KEY=

# ── SMTP (optional — for email sending after payments) ───────────────────────
# SMTP_HOST=smtp.resend.dev
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxx
# SMTP_FROM=LeakLock <hello@yourdomain.com>
